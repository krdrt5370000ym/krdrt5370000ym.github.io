[{"id":"8j3dsRo3TVp8","name":"Sezon 103","host":"Agnieszka Szkuta","description":"<div class=\"x_elementToProof\"><div class=\"x_elementToProof\"><span class=\"x_elementToProof\" data-olk-copy-source=\"MessageBody\">To program dla miłośników seriali i kina. Dla tych, którzy po seansie w kinie czekają na napisy, śledzą nie tylko akcję, ale lubią zaglądać za kulisy. Dla tych, którzy chcą wiedzieć jak naprawdę powstają duże i małe produkcje. Będę opowiadać o premierach z małego i dużego ekranu i korzystając okazji przypomnę o ich filmowych kuzynach i przodkach&nbsp;</span></div></div><div class=\"x_elementToProof\"><div class=\"x_elementToProof\"><span class=\"x_elementToProof\">Będzie więc o historii kina, nie tylko tego&nbsp;ambitnego&nbsp;ale&nbsp;też&nbsp;popularnego, o współczesnych trendach i o tym, co dzieje się za kamerą. Nie zabraknie także historii o muzyce, jaki wpływ ma na narrację sceny i jak buduje najlepsze wspomnienia związane z kinem.&nbsp; Będą&nbsp;także&nbsp;goście – twórcy i filmoznawcy.&nbsp;</span></div></div>","onair":"sobota, 15:00-16:00","category":["Podcasty"],"thumbnail_uri":"https://i.ibb.co/TMrSTdBY/SEZON-103-1.png","url_podcast":"https://radiokolor.pl/programy-podcastow/sezon-103/","podcast":"WPPodcastRK('Sezon 103');"},{"id":"XgEGbhFm7YAe","name":"Kawałek Polski","host":"Martyna Wawryło","description":"„W polskiej muzyce nic się nie dzieje!”. Ile razy to słyszeliśmy… W każdy poniedziałek po 21:00 Martyna Wawryło przekona Was, że to zdanie nie ma racji bytu. Kawałek Polski to godzina z najlepszą polską muzyką. Spotkania z artystami i muzyka, która już stała się klasyką, albo jest na najlepszej drodze by była tak oceniana w przyszłości.","onair":"poniedziałek, 21:00-22:00","category":["Podcasty"],"thumbnail_uri":"https://i.ibb.co/TMj2v6Gv/Kawalek-Polski.jpg","url_podcast":"https://radiokolor.pl/programy-podcastow/kawalek-polski/","podcast":"WPPodcastRK('Kawałek Polski');"},{"id":"a09cA3okLdmm","name":"Zwierzaki na fali","host":"Natasza Kotarska","onair":"sobota, 15:00-16:00","category":["Podcasty"],"thumbnail_uri":"https://i.ibb.co/b5sB1YFq/Zwierzaki-na-fali-BEZ-SPONSORA.png","url_podcast":"https://radiokolor.pl/programy-podcastow/zwierzaki-na-fali/","podcast":"WPPodcastRK('Zwierzaki na fali');","hide_in_podcast":true},{"id":"vPreqKLTgtPD","name":"(S)Ala gimnastyczna","host":"Radio Kolor","category":["Podcasty"],"thumbnail_uri":"https://i.ibb.co/hR2V6StY/sAla-gimnastyczna.jpg","url_podcast":"https://radiokolor.pl/programy-podcastow/sala-gimnastyczna/","podcast":"WPPodcastRK('(S)Ala gimnastyczna');"},{"id":"1tFZ5YiNPO4a","name":"Burza mózgów","host":"Katarzyna Burzyńska-Sychowicz","category":["Podcasty"],"thumbnail_uri":"https://i.ibb.co/WpM2sF7Y/original_1704912730_BURZA_MOZGOW.jpg","url_podcast":"https://radiokolor.pl/programy-podcastow/burza-mozgow/","podcast":"WPPodcastRK('Burza mózgów');","hide_in_podcast":true},{"id":"fmQIkTArdwwb","name":"Doktor Kolor","host":"Radio Kolor","category":["Podcasty"],"thumbnail_uri":"https://i.ibb.co/ycRBDRx0/original_1705063901_DOKTOR_KOLOR.jpg","url_podcast":"https://radiokolor.pl/programy-podcastow/doktor-kolor/","podcast":"WPPodcastRK('Doktor Kolor');","hide_in_podcast":true},{"id":"xUHk0N98p3wr","name":"Eksperci mówią","host":"Radio Kolor","category":["Podcasty"],"thumbnail_uri":"https://i.ibb.co/yJP71w9/Dzien-z.jpg","url_podcast":"https://radiokolor.pl/programy-podcastow/inne/","hide_in_podcast":true},{"id":"jxtWrLnsSWIn","name":"MZAntologia","host":"Radio Kolor","category":["Podcasty"],"thumbnail_uri":"https://i.ibb.co/5XMQvJPZ/MZAntologia-2.png","url_podcast":"https://radiokolor.pl/programy-podcastow/mzantologia/","podcast":"WPPodcastRK('MZAntologia');"},{"id":"eMIxbWSdv7uY","name":"Najpiękniejsze piosenki świata","host":"Beata Pawlikowska","description":"<div class=\"elementor-widget-container\"><h2 class=\"wp-block-heading\">Beata Pawlikowska powraca do Waszych głośników! Rusza jej najnowszy muzyczny podcast „Najpiękniejsze piosenki świata”. Do usłyszenia w każdą niedzielę na radiokolor.pl.</h2><p>W każdą niedzielę w dziale podcasty znajdziecie świeży odcinek podcastu Waszej ulubionej blondynki! Co w nim usłyszcie? To najlepiej wyjaśni jego autorka – Beata Pawlikowska:</p><p><em>Najpiękniejsze piosenki świata i opowieści z podróży. Opowiem o tym jak powstał blues i jak wygląda tworzenie płyty, o przygodach w pociągu, na stepie, w pustyni i w puszczy, będę cytować fragmenty autobiografii artystów i wywiadów z muzykami, czasem będę nadawać z dżungli albo z wysokich peruwiańskich gór. To będzie podróż przez fascynujące historie i muzykę, która napełnia świat dobrą energią pasji i miłości.</em><br><em><br>Audycję zgodziło się przyjąć do swoich podcastów Radio Kolor, radiokolor.pl, za co jestem bardzo wdzięczna </em></p><p></p><p><em>W Radiu Kolor zaczynałam pracę w Warszawie trochę ponad trzydzieści lat temu.<br>Audycja jest dziełem czystej pasji. Nie pobieram żadnego honorarium, nie mam sponsora ani reklamodawców. Jeżeli chcesz zostać Patronem audycji, zapraszam do serwisu Patronite: <a href=\"https://patronite.pl/BeataPawlikowska\" target=\"_blank\" rel=\"noreferrer noopener\">https://patronite.pl/BeataPawlikowska</a></em><br><em><br>Chcę przybliżyć Wam niezwykły świat muzyki i podróży. Wybierz się ze mną pociągiem przez afrykańską noc, obudź się o świcie w Indiach, wędruj przez Himalaje i amazońską dżunglę. Towarzyszyć nam będą artyści, którzy stworzyli muzykę płynącą wprost z namiętności serca, pełną wolności i inspiracji: The Beatles, Elvis Presley, The Doors, Pink Floyd, Bob Dylan, Prince, Sting, George Michael, Miles Davis, Chet Baker, Ella Fitzgerald, Nat King Cole, Frank Sinatra, Bee Gees, Paul Simon i wielu innych. </em></p><p><em>Serdecznie zapraszam!</em></p><img src=\"https://i.ibb.co/K8ZM4rp/header-signature-300x68.webp\"><p><strong>Posłuchaj programu:</strong></p><p><a href=\"https://radiokolor.pl/programy-podcastow/najpiekniejsze-piosenki-swiata/\" data-type=\"link\" data-id=\"https://radiokolor.pl/programy-podcastow/najpiekniejsze-piosenki-swiata/\" target=\"_blank\" rel=\"noreferrer noopener\"><strong>Podcasty – sezon 1</strong></a><br><br><strong><a href=\"https://radiokolor.pl/programy-podcastow/najpiekniejsze-piosenki-swiata2/\" data-type=\"link\" data-id=\"https://radiokolor.pl/programy-podcastow/najpiekniejsze-piosenki-swiata2/\" target=\"_blank\" rel=\"noreferrer noopener\">Podcasty – sezon 2</a></strong></p></div>","category":["Podcasty"],"thumbnail_uri":"https://i.ibb.co/sdX1sJrv/NPS-kwadrat2-e1737580305533.jpg","url_podcast":"https://radiokolor.pl/programy-podcastow/najpiekniejsze-piosenki-swiata2/","podcast":"WPPodcastRK('Najpiękniejsze piosenki świata');"},{"id":"i7bVgz4nOSX6","name":"Pełna kultura","host":"Radio Kolor","category":["Podcasty"],"thumbnail_uri":"https://i.ibb.co/LXfQj03b/Pelna-Kultura2x1-1.png","url_podcast":"https://radiokolor.pl/programy-podcastow/pelna-kultura/","podcast":"WPPodcastRK('Pełna kultura');"},{"id":"U6gi9TRB4RF5","name":"Pomoc kuchenna","host":"Radio Kolor","category":["Podcasty"],"thumbnail_uri":"https://i.ibb.co/M52BTtpC/original_1705659068Pomoc_Kuchenna.jpg","url_podcast":"https://radiokolor.pl/programy-podcastow/pomoc-kuchenna/","podcast":"WPPodcastRK('Pomoc kuchenna');","hide_in_podcast":true},{"id":"B1xMwCe9gDmc","name":"Rozmowy / wywiady","host":"Radio Kolor","category":["Podcasty"],"thumbnail_uri":"https://i.ibb.co/0pmx9k8c/Rozmowa-w-Radiu-Kolor.png","url_podcast":"https://radiokolor.pl/programy-podcastow/rozmowy-wywiady/","hide_in_podcast":true},{"id":"7avC4iP4izNv","name":"Sekrety brzmienia","host":"Radio Kolor","category":["Podcasty"],"thumbnail_uri":"https://i.ibb.co/0RXFG2fn/original_1705332395Sekrety_brzmienia.jpg","url_podcast":"https://radiokolor.pl/programy-podcastow/sekrety-brzmienia/","podcast":"WPPodcastRK('Sekrety brzmienia');"},{"id":"gR0dpZa2cYHE","name":"Smaki Mazowsza","host":"Radio Kolor","category":["Podcasty"],"thumbnail_uri":"https://i.ibb.co/v63K3dD0/SMAKI-MAZOWSZA-2-1.png","url_podcast":"http